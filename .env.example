# ---------- Telegram ----------
BOT_TOKEN=your_telegram_bot_token_here

# ---------- Claude (Anthropic) ----------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------- Джерело каталогу ----------
# google_sheets (за замовчуванням) | csv
# csv не потребує жодного налаштування Google Cloud — простіший старт,
# але потребує ручного оновлення файлу + передеплою (як старий catalog.json).
CATALOG_PROVIDER=google_sheets

# ---------- Google Sheets: каталог товарів (якщо CATALOG_PROVIDER=google_sheets) ----------
# ID таблиці — беремо з URL між /d/ та /edit:
# https://docs.google.com/spreadsheets/d/ЦЕЙ_ID_ТУТ/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id_here

# Email Service Account (видає Google Cloud Console при створенні),
# виглядає приблизно так: order-bot@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email_here

# Приватний ключ Service Account (з JSON-файлу, поле "private_key").
# ВАЖЛИВО: вставляйте одним рядком, замінивши реальні переноси рядка
# на буквені "\n" — код сам розпакує їх назад. Обов'язково в лапках.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Аркуш і діапазон колонок (за замовчуванням не обов'язково міняти).
# Формат: НазваАркуша!ПершаКолонка{ПершийРядокДаних}:ОстанняКолонка
GOOGLE_SHEETS_RANGE=Каталог!A2:Q

# ---------- CSV: каталог товарів (якщо CATALOG_PROVIDER=csv) ----------
# Шлях до CSV-файлу з товарами (у тому ж форматі, що examples/catalog-template.csv)
CSV_CATALOG_PATH=./catalog-data.csv

# ---------- Кеш і синхронізація каталогу ----------
# Як часто (у мілісекундах) каталог автоматично оновлюється з джерела.
# 60000 = 1 хвилина. Не варто ставити менше 30000 (30с) для Google Sheets —
# у нього є ліміти на кількість запитів за хвилину.
CATALOG_SYNC_INTERVAL_MS=60000

# Скільки часу (мс) вважати кешовані дані "свіжими" без примусового оновлення.
CATALOG_CACHE_TTL_MS=60000

# Скільки разів повторити спробу при тимчасовій помилці Google API (429/5xx).
CATALOG_SYNC_MAX_RETRIES=3

# Базова затримка (мс) перед повторною спробою; збільшується експоненційно
# (1000 -> 2000 -> 4000 ...).
CATALOG_SYNC_RETRY_BASE_DELAY_MS=1000

# ---------- Ціноутворення / націнка ----------
# Ціна в Google Таблиці/CSV — це ЗАКУПІВЕЛЬНА ціна. Клієнт бачить лише
# кінцеву ціну після застосування націнки, розраховану автоматично.

# Головний вимикач. false = показувати закупівельну ціну як є (без націнки).
MARKUP_ENABLED=true

# percentage | fixed | combined
MARKUP_TYPE=percentage

# Відсоток націнки (percentage і combined). Приклад: 30 = +30%.
MARKUP_PERCENT=30

# Фіксована сума націнки в грн (fixed і combined). Приклад: 100 = +100 грн.
MARKUP_FIXED=0

# Округлення кінцевої ціни до найближчого кратного (у грн).
# 1 = до цілого числа, 10 = до найближчих 10 грн (напр. 1953 -> 1950).
# 0 або від'ємне = без округлення.
PRICE_ROUND_TO=10

# ---------- Адмінська команда /refreshcatalog ----------
# Ваш особистий Telegram numeric ID (дізнатися можна у бота @userinfobot).
# Якщо не вказати — команда /refreshcatalog буде повністю вимкнена.
OWNER_TELEGRAM_ID=your_telegram_user_id_here

# ---------- Логування ----------
# error | warn | info | debug
LOG_LEVEL=info
